{
  "$schema": "https://raw.githubusercontent.com/nickelpack/tauri/v2/crates/tauri-config-schema/schema.json",
  "productName": "Qaio",
  "identifier": "com.qaio.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Qaio",
        "width": 1440,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": true,
        "transparent": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/getqaio/qaio/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQwMjVGODAwMEQxMzNERkQKUldUOVBSTU5BUGdsUUZxM2VCQ1JDb0orYTJHbzVObjdKa1N1RVdIdTJTYUtZL2p0bjB0UmQ1N3IK"
    },
    "deep-link": {
      "desktop": {
        "schemes": ["qaio"]
      }
    }
  },
  "bundle": {
    "createUpdaterArtifacts": false,
    "active": true,
    "targets": ["app", "dmg", "nsis", "msi"],
    "externalBin": ["binaries/qaio-engine"],
    "resources": {
      "resources/bin": "bin",
      "resources/store/": "store/"
    },
    "macOS": {
      "signingIdentity": "-",
      "entitlements": "entitlements.plist",
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "wix": {
        "language": ["en-US"]
      },
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
